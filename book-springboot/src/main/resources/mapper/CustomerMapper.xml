<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.CustomerMapper">

    <resultMap id="customerMap" type="com.example.entity.Customer">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="phone" column="phone"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="customerMap">
        SELECT * FROM customers ORDER BY id DESC
    </select>

    <select id="findById" resultMap="customerMap">
        SELECT * FROM customers WHERE id = #{id}
    </select>

    <select id="findByPhone" resultMap="customerMap">
        SELECT * FROM customers WHERE phone = #{phone}
    </select>

    <select id="search" resultMap="customerMap">
        SELECT * FROM customers
        WHERE 1=1
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                     OR phone LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="gender != null and gender != ''">
                AND gender = #{gender}
            </if>
        ORDER BY id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO customers (name, gender, phone, created_at)
        VALUES (#{name}, #{gender}, #{phone}, #{createdAt})
    </insert>

    <update id="update">
        UPDATE customers SET name = #{name}, gender = #{gender}, phone = #{phone}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM customers WHERE id = #{id}
    </delete>

    <select id="existsById" resultType="boolean">
        SELECT COUNT(*) > 0 FROM customers WHERE id = #{id}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM customers
    </select>

    <select id="existsByPhone" resultType="boolean">
        SELECT COUNT(*) > 0 FROM customers
        WHERE phone = #{phone}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

</mapper>
